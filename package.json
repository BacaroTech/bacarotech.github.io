      "autoprefixer": "github.com/zetxek/adritian-free-hugo-theme",
      "bootstrap": "github.com/zetxek/adritian-free-hugo-theme",
      "bootstrap-print-css": "github.com/zetxek/adritian-free-hugo-theme",
      "postcss": "github.com/zetxek/adritian-free-hugo-theme",
      "postcss-cli": "github.com/zetxek/adritian-free-hugo-theme"
    }
  },
  "dependencies": {
    "chrono-node": "^2.9.0",
    "dompurify": "^3.3.1",
    "fuse.js": "^7.1.0",
    "glob": "^13.0.6",
    "googleapis": "^144.0.0",
    "readline-sync": "^1.4.10",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@zetxek/adritian-theme-helper": "^1.0.5",
    "autoprefixer": "^10.4.17",
    "bootstrap": "^5.3.7",
    "bootstrap-print-css": "^1.0.0",
    "postcss": "^8.5.4",
    "postcss-cli": "^11.0.0"
  },
  "name": "bacarotech.github.io",
  "version": "1.0.0",
  "scripts": {
    "content": "node scripts/make-post.js",
    "post": "node scripts/make-post.js post",
    "redirect": "node scripts/make-post.js redirect",
    "author": "node scripts/make-author.js",
    "install": "npm install && hugo mod get -u",
    "cache": "hugo --gc && hugo gen chromastyles --style=catppuccin-frappe > assets/code-highlight.css",
    "clean": "hugo --gc && hugo mod get -u ./... && hugo mod tidy && hugo mod get -u && find . -type d -empty -delete",
    "run": "hugo server --disableFastRender --renderToMemory",
    "gomodule": "hugo mod get -u ./... && hugo mod tidy && hugo mod get -u",
    "update": "npm update",
    "hugo": "hugo server --disableFastRender --renderToMemory",
    "develop": "hugo server --disableFastRender --renderToMemory",
    "developfuture": "hugo server --disableFastRender --buildFuture --renderToMemory",
    "developall": "hugo server --disableFastRender --buildFuture --buildDrafts --renderToMemory",
    "build": "hugo --gc && hugo mod get -u && hugo",
    "deploy": "npm update && hugo --minify",
    "broadcast": "hugo server --disableFastRender --buildFuture --buildDrafts -bind=0.0.0.0",
    "deploy:prod": "npm update && hugo mod get -u && hugo --minify",
    "youtube": "node scripts/generate-youtube-posts.js",
    "youtube-posts": "node scripts/generate-youtube-posts.js"
  }
}
